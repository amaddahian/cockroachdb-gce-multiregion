project_id  = "my-gcp-project-id"
admin_cidrs = ["1.2.3.4/32"]

ssh_user        = "crdb"
ssh_pubkey_path = "~/.ssh/id_ed25519.pub"

# Region/zone default to us-central1 (the cluster's primary region by default).
# Override only if you changed var.topology in the cluster stack.
# region = "us-central1"
# zone   = "us-central1-a"

# Must match var.network_name in the cluster stack (default: "crdb").
# network_name = "crdb"

# n2-standard-4 is enough for kv/tpcc smoke runs. Bump for high-throughput.
machine_type      = "n2-standard-4"
boot_disk_size_gb = 50
