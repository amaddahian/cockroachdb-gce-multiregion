{#- Multi-region zone configuration template.
    Rendered by ansible/roles/cockroachdb/tasks/zone_configs.yml from these vars
    (sourced from terraform output ansible_group_vars):
      crdb_num_replicas       int   total replicas/voters across the cluster
      crdb_topology           list  [{locality, node_count}, ...] in lease-preference order

    With the default 5-node 2/2/1 topology this renders byte-identical to the
    prior hand-maintained zone-configs.sql.
-#}
-- Multi-region zone configuration for the cluster.
-- Topology: {{ crdb_num_replicas }} replicas, voters split {{ crdb_topology | map(attribute='node_count') | join('/') }} across {{ crdb_topology | map(attribute='locality') | join(' / ') }}.
-- Lease preference: {{ crdb_topology | map(attribute='locality') | join(' > ') }}.

ALTER DATABASE system CONFIGURE ZONE USING
    range_min_bytes = 134217728,
    range_max_bytes = 536870912,
    gc.ttlseconds = 90000,
    num_replicas = {{ crdb_num_replicas }},
    num_voters = {{ crdb_num_replicas }};

ALTER RANGE default CONFIGURE ZONE USING
    range_min_bytes = 134217728,
    range_max_bytes = 536870912,
    gc.ttlseconds = 14400,
    num_replicas = {{ crdb_num_replicas }},
    num_voters = {{ crdb_num_replicas }},
    constraints = '{ {%- for r in crdb_topology -%}+region={{ r.locality }}: {{ r.node_count }}{%- if not loop.last %}, {% endif -%}{%- endfor -%} }',
    voter_constraints = '{ {%- for r in crdb_topology -%}+region={{ r.locality }}: {{ r.node_count }}{%- if not loop.last %}, {% endif -%}{%- endfor -%} }',
    lease_preferences = '[{%- for r in crdb_topology -%}[+region={{ r.locality }}]{%- if not loop.last %}, {% endif -%}{%- endfor -%}]';

ALTER RANGE liveness CONFIGURE ZONE USING
    range_min_bytes = 134217728,
    range_max_bytes = 536870912,
    gc.ttlseconds = 600,
    num_replicas = {{ crdb_num_replicas }},
    num_voters = {{ crdb_num_replicas }};

ALTER RANGE meta CONFIGURE ZONE USING
    range_min_bytes = 134217728,
    range_max_bytes = 536870912,
    gc.ttlseconds = 3600,
    num_replicas = {{ crdb_num_replicas }},
    num_voters = {{ crdb_num_replicas }};

ALTER RANGE system CONFIGURE ZONE USING
    range_min_bytes = 134217728,
    range_max_bytes = 536870912,
    gc.ttlseconds = 90000,
    num_replicas = {{ crdb_num_replicas }},
    num_voters = {{ crdb_num_replicas }};

ALTER RANGE timeseries CONFIGURE ZONE USING
    gc.ttlseconds = 14400;

