.terraform/
*.tfstate
*.tfstate.*
*.tfplan
crash.log
crash.*.log

# .terraform.lock.hcl is intentionally NOT ignored — it should be committed
# so collaborators get identical provider versions (per Terraform docs).

# user-specific values
*.tfvars
!terraform.tfvars.example

# generated TLS material — never commit
ansible/certs/

# generated Ansible inventory + group_vars — content depends on terraform state
ansible/inventory/hosts.yml
ansible/inventory/group_vars/

# Ansible runtime artifacts
ansible/.ansible_facts/
*.retry
